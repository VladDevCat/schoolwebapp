@{
    ViewData["Title"] = "Импорт класса";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Excel-импорт</p>
        <h1>Загрузить список класса</h1>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
</section>

<form class="editor-panel" asp-action="Import" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="import-guide">
        <h2>Формат таблицы</h2>
        <p>Первая строка может быть заголовком. Колонки: ФИО, Класс, Email, Логин, Пароль. Email, логин и пароль необязательны.</p>
    </div>
    <div class="form-field">
        <label class="form-label" for="file">Excel-файл .xlsx</label>
        <input class="form-control" id="file" name="file" type="file" accept=".xlsx" />
    </div>
    <div class="form-actions">
        <button class="btn btn-primary" type="submit">Импортировать</button>
        <a class="btn btn-light" asp-action="Index">Отмена</a>
    </div>
</form>
