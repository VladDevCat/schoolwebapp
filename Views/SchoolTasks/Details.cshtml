@model SchoolTask
@using swa.Models
@{
    ViewData["Title"] = "Карточка задачи";
    string StatusLabel(SchoolTaskStatus status) => status switch
    {
        SchoolTaskStatus.Planned => "Запланировано",
        SchoolTaskStatus.InProgress => "В работе",
        SchoolTaskStatus.Completed => "Готово",
        _ => status.ToString()
    };
    string PriorityLabel(TaskPriority priority) => priority switch
    {
        TaskPriority.Low => "Низкий",
        TaskPriority.Medium => "Средний",
        TaskPriority.High => "Высокий",
        _ => priority.ToString()
    };
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Карточка задачи</p>
        <h1>@Model.Title</h1>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
</section>

<section class="details-panel priority-@Model.Priority.ToString().ToLowerInvariant()">
    <div class="task-topline">
        <span class="subject-chip">@Model.Subject</span>
        <span class="status-pill status-@Model.Status.ToString().ToLowerInvariant()">@StatusLabel(Model.Status)</span>
    </div>

    <dl class="details-grid">
        <div>
            <dt>Срок сдачи</dt>
            <dd>@Model.DueDate.ToString("dd.MM.yyyy")</dd>
        </div>
        <div>
            <dt>Приоритет</dt>
            <dd>@PriorityLabel(Model.Priority)</dd>
        </div>
        <div>
            <dt>Преподаватель</dt>
            <dd>@(string.IsNullOrWhiteSpace(Model.Teacher) ? "Не указан" : Model.Teacher)</dd>
        </div>
        <div>
            <dt>Ученик</dt>
            <dd>@(Model.AssignedStudent is null ? "Для класса" : $"{Model.AssignedStudent.ClassName} · {Model.AssignedStudent.FullName}")</dd>
        </div>
        <div>
            <dt>Создано</dt>
            <dd>@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
        </div>
    </dl>

    <div class="details-description">
        <h2>Описание</h2>
        <p>@(string.IsNullOrWhiteSpace(Model.Description) ? "Описание пока не добавлено." : Model.Description)</p>
    </div>

    <div class="form-actions">
        <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post">
            <button class="btn @(Model.Status == SchoolTaskStatus.Completed ? "btn-outline-secondary" : "btn-success")" type="submit">
                @(Model.Status == SchoolTaskStatus.Completed ? "Вернуть в работу" : "Отметить готовой")
            </button>
        </form>
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Редактировать</a>
    </div>
</section>
